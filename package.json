{
  "name": "kozou-desktop",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "kozou Desktop — Semantic Map (validation-first MVP): a read-only, cross-database visual surface for the semantic model kozou compiles from your PostgreSQL schema.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "svelte-check --tsconfig ./tsconfig.web.json --fail-on-warnings",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "test:e2e": "playwright test",
    "check:treeshake": "node scripts/check-treeshake.mjs",
    "check:egress": "node scripts/check-egress-static.mjs",
    "dist": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-vite build && pnpm check:treeshake && pnpm check:egress && electron-builder --mac --arm64"
  },
  "dependencies": {
    "@kozou/core": "^1.15.1",
    "@kozou/introspect": "^1.15.1",
    "@kozou/mcp": "^1.15.1"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.50.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^24.0.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "elkjs": "^0.11.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.20.0",
    "kozou": "1.15.1",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
